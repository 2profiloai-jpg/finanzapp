rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return true; // Allow access without auth for simplicity as requested
    }
    
    function hasOnlyAllowedFields(allowedFields) {
      return request.resource.data.keys().hasOnly(allowedFields);
    }
    
    function hasRequiredFields(requiredFields) {
      return request.resource.data.keys().hasAll(requiredFields);
    }
    
    function isPositiveNumber(field) {
      return request.resource.data[field] is number && request.resource.data[field] >= 0;
    }
    
    function isValidString(field, maxLength) {
      return request.resource.data[field] is string && request.resource.data[field].size() <= maxLength;
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidWorkEntry() {
      return hasOnlyAllowedFields(['id', 'day', 'hours', 'hourlyRate', 'totalEarned', 'note', 'createdAt']) &&
             hasRequiredFields(['id', 'day', 'hours', 'hourlyRate', 'totalEarned', 'createdAt']) &&
             isValidString('id', 50) &&
             isValidString('day', 20) &&
             isPositiveNumber('hours') &&
             isPositiveNumber('hourlyRate') &&
             isPositiveNumber('totalEarned') &&
             (!('note' in request.resource.data) || isValidString('note', 500)) &&
             request.resource.data.createdAt is number;
    }

    function isValidExpense() {
      return hasOnlyAllowedFields(['id', 'day', 'amount', 'category', 'note', 'createdAt']) &&
             hasRequiredFields(['id', 'day', 'amount', 'category', 'createdAt']) &&
             isValidString('id', 50) &&
             isValidString('day', 20) &&
             isPositiveNumber('amount') &&
             isValidString('category', 50) &&
             (!('note' in request.resource.data) || isValidString('note', 500)) &&
             request.resource.data.createdAt is number;
    }

    function isValidSettings() {
      return hasOnlyAllowedFields(['defaultRate', 'theme']) &&
             hasRequiredFields(['defaultRate', 'theme']) &&
             isPositiveNumber('defaultRate') &&
             request.resource.data.theme in ['light', 'dark'];
    }

    // ===============================================================
    // Rules
    // ===============================================================
    match /users/{userId} {
      match /workEntries/{entryId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidWorkEntry();
        allow update: if isOwner(userId) && isValidWorkEntry() && request.resource.data.createdAt == resource.data.createdAt;
        allow delete: if isOwner(userId);
      }
      
      match /expenses/{expenseId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidExpense();
        allow update: if isOwner(userId) && isValidExpense() && request.resource.data.createdAt == resource.data.createdAt;
        allow delete: if isOwner(userId);
      }
      
      match /settings/profile {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidSettings();
        allow update: if isOwner(userId) && isValidSettings();
      }
    }
  }
}
